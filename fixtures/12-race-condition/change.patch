--- a/src/counter.rs
+++ b/src/counter.rs
@@ -0,0 +1,16 @@
+use std::thread;
+
+pub fn count_parallel(n: usize) -> usize {
+    let mut counter = 0usize;
+    let handles: Vec<_> = (0..n)
+        .map(|_| {
+            thread::spawn(move || {
+                counter += 1;
+            })
+        })
+        .collect();
+    for h in handles {
+        let _ = h.join();
+    }
+    counter
+}
