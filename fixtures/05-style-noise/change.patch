+pub fn double_value(x: i32) -> i32 {
+    return x * 2;
+}
+
+pub fn triple_value(x: i32) -> i32 {
+    x * 3
+}
+
+pub fn   add_values(   a: i32,    b: i32   ) -> i32 {
+    let result = a + b;
+    return result;
+}
+
+pub fn subtract_values(a: i32, b: i32) -> i32 {
+    a - b
+}
